# PageFly environment variables
# Copy to .env and fill in values. Env vars override config.json when set.
#
# Minimal env-only deployment (no config.json needed):
#   ANTHROPIC_API_KEY, PAGEFLY_EMAIL, PAGEFLY_PASSWORD

# ── Minimal (required for env-only boot) ──
ANTHROPIC_API_KEY=sk-ant-xxx
PAGEFLY_EMAIL=you@example.com
PAGEFLY_PASSWORD=change-me-to-a-strong-password

# ── Optional: extra capabilities ──
OPENAI_API_KEY=sk-xxx             # voice transcription
MISTRAL_API_KEY=xxx               # image OCR
TELEGRAM_BOT_TOKEN=xxx            # Telegram ingestion channel
TELEGRAM_CHAT_ID=xxx               # Your personal chat ID

# ── Overrides ──
ANTHROPIC_BASE_URL=https://api.anthropic.com
DATABASE_URL=sqlite:///data/pagefly.db
API_PORT=8000
API_MASTER_TOKEN=change-this-to-a-secure-token
LOG_LEVEL=INFO
