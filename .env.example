# PageFly environment variables
# Copy to .env and fill in values. These override config.json when set.

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI (for GPT-4o Transcribe)
OPENAI_API_KEY=sk-xxx

# Mistral (for OCR)
MISTRAL_API_KEY=xxx

# Telegram Bot
TELEGRAM_BOT_TOKEN=xxx
TELEGRAM_CHAT_ID=xxx

# Database
DATABASE_URL=sqlite:///data/pagefly.db

# API
API_PORT=8000
API_MASTER_TOKEN=change-this-to-a-secure-token

# App
LOG_LEVEL=INFO
